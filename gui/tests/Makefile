	cd /home/alex/epitech/tek2/g-yep-400/zappy && $(MAKE) $(MAKESILENT) -f gui/tests/CMakeFiles/unit_tests.dir/build.make gui/tests/CMakeFiles/unit_tests.dir/test_team.cpp.i
.PHONY : test_team.cpp.i

test_team.s: test_team.cpp.s
.PHONY : test_team.s

# target to generate assembly for a file
test_team.cpp.s:
	cd /home/alex/epitech/tek2/g-yep-400/zappy && $(MAKE) $(MAKESILENT) -f gui/tests/CMakeFiles/unit_tests.dir/build.make gui/tests/CMakeFiles/unit_tests.dir/test_team.cpp.s
.PHONY : test_team.cpp.s

